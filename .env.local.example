# Salin file ini menjadi .env.local lalu isi dengan nilai dari project Supabase Anda
# (Project Settings > API di dashboard Supabase)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Hanya dipakai di server (route handlers / server actions). JANGAN pernah
# expose key ini ke client / commit ke git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
