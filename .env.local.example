# Salin file ini menjadi .env.local lalu isi dengan nilai Anda sendiri

# --- Password bersama tim (bukan akun per orang) ---
APP_PASSWORD=ganti-dengan-password-tim-anda

# --- Google Sheets sebagai database (lewat Google Apps Script Web App) ---
# Lihat README bagian "Setup Google Sheets" + file google-apps-script/Code.gs
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/xxxxxxxxxxxxxxxxxxxx/exec
GOOGLE_SCRIPT_SECRET=harus-sama-persis-dengan-SECRET-di-Code.gs

# --- (Opsional) Menghubungkan spreadsheet "Cost Data" Anda yang sudah ada,
# sebagai referensi kode/nama/spek/harga di Master Barang. Kosongkan kalau
# tidak dipakai. Bisa lebih dari satu tab, pisahkan dengan koma.
GOOGLE_COST_DATA_SHEET_ID=isi_id_spreadsheet_cost_data_disini
GOOGLE_COST_DATA_TABS=MASTER DATA (Small EQ),MASTER DATA (Big EQ),MASTER DATA (MAT)
